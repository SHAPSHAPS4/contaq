{
  "openapi": "3.0.3",
  "info": {
    "title": "Contraq API",
    "description": "M&E Estimation & Contract Management platform API. AI-powered quote extraction, pricing, and project management for UK specialist subcontractors.",
    "version": "1.0.0",
    "contact": { "email": "sam@foxdoninsulation.co.uk" }
  },
  "servers": [
    { "url": "https://contraq.uk", "description": "Production" },
    { "url": "http://localhost:3001", "description": "Local development" }
  ],
  "tags": [
    { "name": "Auth", "description": "Authentication & user management" },
    { "name": "Data", "description": "CRUD operations for platform data" },
    { "name": "AI - Extraction", "description": "AI-powered drawing and spec extraction (Stages 1-3)" },
    { "name": "AI - Learning", "description": "Feedback loop and knowledge base management" },
    { "name": "Pricing", "description": "Pricing engine and quote management" },
    { "name": "Validation", "description": "Extraction quality gate" },
    { "name": "Invoices", "description": "Invoice and variation management" },
    { "name": "Versioning", "description": "Quote version control" },
    { "name": "Similarity", "description": "Similar projects comparison" },
    { "name": "Drawing Register", "description": "Multi-drawing project management" },
    { "name": "Billing", "description": "Stripe billing integration" },
    { "name": "Beta", "description": "Beta programme management" },
    { "name": "Upload", "description": "File upload endpoints" },
    { "name": "System", "description": "Health checks and status" }
  ],
  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT",
        "description": "Supabase JWT token from /api/auth/login"
      }
    },
    "schemas": {
      "Error": {
        "type": "object",
        "properties": {
          "success": { "type": "boolean", "example": false },
          "error": {
            "type": "object",
            "properties": {
              "code": { "type": "string", "example": "VALIDATION_FAILED" },
              "message": { "type": "string", "example": "Email is required" },
              "details": { "type": "array", "items": { "type": "object" } }
            }
          }
        }
      },
      "ExtractionItem": {
        "type": "object",
        "properties": {
          "description": { "type": "string", "example": "22mm Copper pipe Type X to BS EN 1057" },
          "specification": { "type": "string", "example": "BS EN 1057, 22mm dia, R250 half-hard" },
          "quantity": { "type": "number", "example": 50 },
          "unit": { "type": "string", "example": "m" },
          "trade": { "type": "string", "enum": ["Mechanical", "Electrical", "Insulation"] },
          "confidence": { "type": "string", "enum": ["High", "Medium", "Low"] },
          "source": { "type": "string", "enum": ["Drawing", "Spec", "Both", "Implicit"] }
        }
      },
      "PricedItem": {
        "type": "object",
        "properties": {
          "description": { "type": "string" },
          "trade": { "type": "string" },
          "quantity": { "type": "number" },
          "unit": { "type": "string" },
          "material_rate": { "type": "number" },
          "labour_rate": { "type": "number" },
          "subtotal": { "type": "number" },
          "total_with_overheads": { "type": "number" },
          "pricing_status": { "type": "string", "enum": ["priced", "unpriced", "manual"] }
        }
      },
      "ScopeGap": {
        "type": "object",
        "properties": {
          "rule_id": { "type": "string", "example": "SC-M-001" },
          "trade": { "type": "string" },
          "description": { "type": "string" },
          "estimated_quantity": { "type": "number" },
          "unit": { "type": "string" },
          "trigger_rule": { "type": "string" },
          "severity": { "type": "string", "example": "SCOPE_GAP" },
          "confidence": { "type": "string", "example": "Medium" }
        }
      }
    }
  },
  "paths": {
    "/api/health": {
      "get": {
        "tags": ["System"],
        "summary": "Health check",
        "responses": { "200": { "description": "Server is running" } }
      }
    },
    "/api/status": {
      "get": {
        "tags": ["System"],
        "summary": "Detailed server status",
        "responses": { "200": { "description": "Server status with uptime, request count, service health" } }
      }
    },
    "/api/auth/signup": {
      "post": {
        "tags": ["Auth"],
        "summary": "Create new user and organisation",
        "requestBody": {
          "required": true,
          "content": { "application/json": { "schema": {
            "type": "object",
            "required": ["email", "password", "name", "companyName"],
            "properties": {
              "email": { "type": "string", "format": "email" },
              "password": { "type": "string", "minLength": 8 },
              "name": { "type": "string" },
              "companyName": { "type": "string" },
              "trade": { "type": "string" },
              "plan": { "type": "string" }
            }
          }}}
        },
        "responses": {
          "200": { "description": "Account created" },
          "400": { "description": "Validation error" },
          "409": { "description": "Email already registered" }
        }
      }
    },
    "/api/auth/login": {
      "post": {
        "tags": ["Auth"],
        "summary": "Authenticate user",
        "requestBody": {
          "required": true,
          "content": { "application/json": { "schema": {
            "type": "object",
            "required": ["email", "password"],
            "properties": {
              "email": { "type": "string", "format": "email" },
              "password": { "type": "string" }
            }
          }}}
        },
        "responses": {
          "200": { "description": "Login successful, returns session token" },
          "401": { "description": "Invalid credentials" }
        }
      }
    },
    "/api/auth/change-password": {
      "post": {
        "tags": ["Auth"],
        "summary": "Change password (authenticated)",
        "security": [{ "bearerAuth": [] }],
        "requestBody": {
          "required": true,
          "content": { "application/json": { "schema": {
            "type": "object",
            "required": ["currentPassword", "newPassword"],
            "properties": {
              "currentPassword": { "type": "string" },
              "newPassword": { "type": "string", "minLength": 8 }
            }
          }}}
        },
        "responses": {
          "200": { "description": "Password updated" },
          "401": { "description": "Current password incorrect" }
        }
      }
    },
    "/api/drawings/extract": {
      "post": {
        "tags": ["AI - Extraction"],
        "summary": "Stage 1: Extract quantities from M&E drawing",
        "description": "Processes a PDF drawing through Claude AI with knowledge base injection. Returns extracted items with quantities, specifications, and confidence levels.",
        "requestBody": {
          "required": true,
          "content": { "application/json": { "schema": {
            "type": "object",
            "properties": {
              "file_id": { "type": "string", "description": "ID from /api/upload/drawing" },
              "drawing_base64": { "type": "string", "description": "Base64-encoded PDF" },
              "project_ref": { "type": "string" },
              "model": { "type": "string", "default": "claude-sonnet-4-6" },
              "max_tokens": { "type": "integer", "default": 12000 }
            }
          }}}
        },
        "responses": { "200": { "description": "Extraction result with items, flags, and KB version" } }
      }
    },
    "/api/specs/analyse": {
      "post": {
        "tags": ["AI - Extraction"],
        "summary": "Stage 2: Analyse specification document",
        "responses": { "200": { "description": "Spec analysis with requirements and schedules" } }
      }
    },
    "/api/takeoff/consolidate": {
      "post": {
        "tags": ["AI - Extraction"],
        "summary": "Stage 3: Consolidate drawing + spec into priced takeoff",
        "description": "Cross-references Stage 1 and Stage 2 outputs. Includes validation gate (blocks poor extractions) and scope completeness check.",
        "requestBody": {
          "required": true,
          "content": { "application/json": { "schema": {
            "type": "object",
            "properties": {
              "drawing_extraction": { "type": "object" },
              "spec_analysis": { "type": "object" },
              "project_ref": { "type": "string" },
              "override_validation": { "type": "boolean", "default": false }
            }
          }}}
        },
        "responses": {
          "200": { "description": "Consolidated takeoff with scope check" },
          "422": { "description": "Extraction quality too low — validation blocked" }
        }
      }
    },
    "/api/pricing/price": {
      "post": {
        "tags": ["Pricing"],
        "summary": "Price takeoff items using rate library",
        "requestBody": {
          "required": true,
          "content": { "application/json": { "schema": {
            "type": "object",
            "required": ["takeoff_items"],
            "properties": {
              "takeoff_items": { "type": "array", "items": { "$ref": "#/components/schemas/ExtractionItem" } },
              "overheads_override": { "type": "object" },
              "project_ref": { "type": "string" }
            }
          }}}
        },
        "responses": { "200": { "description": "Priced items with trade breakdown and grand total" } }
      }
    },
    "/api/validate/extraction": {
      "post": {
        "tags": ["Validation"],
        "summary": "Validate extraction quality (A-F grade)",
        "requestBody": {
          "required": true,
          "content": { "application/json": { "schema": {
            "type": "object",
            "required": ["extraction"],
            "properties": {
              "extraction": { "type": "object" },
              "project_ref": { "type": "string" }
            }
          }}}
        },
        "responses": { "200": { "description": "Validation result with score, grade, and recommendations" } }
      }
    },
    "/api/versions/{quoteRef}/save": {
      "post": {
        "tags": ["Versioning"],
        "summary": "Save new version snapshot of a quote",
        "parameters": [{ "name": "quoteRef", "in": "path", "required": true, "schema": { "type": "string" } }],
        "requestBody": {
          "required": true,
          "content": { "application/json": { "schema": {
            "type": "object",
            "required": ["quote_data"],
            "properties": {
              "quote_data": { "type": "object" },
              "change_note": { "type": "string" }
            }
          }}}
        },
        "responses": { "200": { "description": "Version saved with number and ref" } }
      }
    },
    "/api/versions/{quoteRef}": {
      "get": {
        "tags": ["Versioning"],
        "summary": "Get version history for a quote",
        "parameters": [{ "name": "quoteRef", "in": "path", "required": true, "schema": { "type": "string" } }],
        "responses": { "200": { "description": "Array of version summaries" } }
      }
    },
    "/api/versions/{quoteRef}/compare": {
      "get": {
        "tags": ["Versioning"],
        "summary": "Compare two quote versions",
        "parameters": [
          { "name": "quoteRef", "in": "path", "required": true, "schema": { "type": "string" } },
          { "name": "a", "in": "query", "required": true, "schema": { "type": "integer" } },
          { "name": "b", "in": "query", "required": true, "schema": { "type": "integer" } }
        ],
        "responses": { "200": { "description": "Diff with added/changed/removed items and net delta" } }
      }
    },
    "/api/similarity/find": {
      "post": {
        "tags": ["Similarity"],
        "summary": "Find similar historical projects",
        "requestBody": {
          "required": true,
          "content": { "application/json": { "schema": {
            "type": "object",
            "required": ["extraction_items"],
            "properties": {
              "extraction_items": { "type": "array", "items": { "$ref": "#/components/schemas/ExtractionItem" } },
              "limit": { "type": "integer", "default": 3 }
            }
          }}}
        },
        "responses": { "200": { "description": "Ranked list of similar projects with scores" } }
      }
    },
    "/api/register/create": {
      "post": {
        "tags": ["Drawing Register"],
        "summary": "Create multi-drawing register for a project",
        "requestBody": {
          "required": true,
          "content": { "application/json": { "schema": {
            "type": "object",
            "required": ["project_ref", "drawings"],
            "properties": {
              "project_ref": { "type": "string" },
              "drawings": { "type": "array", "items": { "type": "object", "properties": { "file_id": { "type": "string" }, "original_name": { "type": "string" } } } }
            }
          }}}
        },
        "responses": { "200": { "description": "Register created with drawing metadata" } }
      }
    },
    "/api/register/{projectRef}/process-all": {
      "post": {
        "tags": ["Drawing Register"],
        "summary": "Batch process all pending drawings (async)",
        "parameters": [{ "name": "projectRef", "in": "path", "required": true, "schema": { "type": "string" } }],
        "responses": { "200": { "description": "Processing started — poll GET /api/register/{projectRef} for status" } }
      }
    }
  }
}
