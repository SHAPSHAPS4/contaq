{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "DOCKERFILE",
    "dockerfilePath": "Dockerfile"
  },
  "deploy": {
    "startCommand": "python -c \"import os; port=os.environ.get('PORT','8000'); os.execvp('uvicorn',['uvicorn','main:app','--host','0.0.0.0','--port',port])\""
  }
}
